# Copy to terraform.tfvars and fill in. DO NOT commit real secret values.
# (terraform.tfvars is gitignored; this .example file is safe to commit.)

project_id     = "neuro-d3-staging"
project_number = "601000536186"
region         = "us-west1"
zone           = "us-west1-a"

ar_repo_id = "neuro-d3"

# Prefer immutable digests over :latest once you have real images pushed.
api_image      = "us-west1-docker.pkg.dev/neuro-d3-staging/neuro-d3/api:latest"
frontend_image = "us-west1-docker.pkg.dev/neuro-d3-staging/neuro-d3/frontend:latest"
airflow_image  = "us-west1-docker.pkg.dev/neuro-d3-staging/neuro-d3/airflow:latest"

# Cloud SQL
db_tier                = "db-f1-micro"
db_deletion_protection = false

# Airflow VM (bump to e2-medium if Airflow OOMs on e2-small)
vm_machine_type = "e2-small"
vm_boot_disk_gb = 30

# Cloud Run
cloudrun_cpu           = "0.25"
cloudrun_memory        = "512Mi"
cloudrun_max_instances = 1
allow_unauthenticated  = true

# Leave empty on the first apply; after the frontend is created, set this to its
# Cloud Run URL (the `frontend_url` output) and re-apply so the API allows CORS.
allowed_origins = "" # e.g. "https://neuro-d3-frontend-xxxxxxxxxx-uw.a.run.app"

# Secrets — leave as placeholders for the first apply, then add real values
# as new secret versions (or set them here in a NON-committed terraform.tfvars).
openrouter_api_key = "REPLACE_ME"
airflow_fernet_key = "REPLACE_ME" # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# CI/CD (GitHub Actions → WIF)
github_repo = "Neuro-D3/neurod3"
# Phase 1 (testing on PRs): false — any ref in github_repo may deploy.
# Phase 2 (go-live): true — only refs/heads/main may deploy.
wif_lock_to_main = false
